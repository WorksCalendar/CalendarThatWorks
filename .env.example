# AI QA Reviewer (scripts/ai-qa-review.mjs)
# ---------------------------------------------------------------------------
# The QA reviewer script can talk to any OpenAI-compatible inference server.
# Copy this file to .env and fill in the values for your setup.
# .env is already in .gitignore — never commit real keys.

# --- OpenAI (cloud) ----------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1   # optional; defaults to OpenAI

# --- LM Studio (local) -------------------------------------------------------
# LM_STUDIO_API_KEY=lm-studio                 # any non-empty string works
# LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1

# --- Model override ----------------------------------------------------------
# LM_STUDIO_MODEL=local-model                 # model name served by LM Studio
