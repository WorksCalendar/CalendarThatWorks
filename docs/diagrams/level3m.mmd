flowchart TD
    A["live filter state\n{ categories: Set&lt;string&gt;\n  resources: Set&lt;string&gt;\n  search: string\n  dateRange?: { start: Date, end: Date } }"]:::g
    B["saveView(name, filters, opts)\nsrc/hooks/useSavedViews.ts\nview, groupBy, sort, conditions, color…"]:::g
    C["serializeFilters(filters)\nJSON.stringify replacer:\n  Set → [...value]\nJSON.parse → plain object"]:::g
    D["SavedView\n{ id, name, createdAt, color, view\n  groupBy, sort, conditions\n  filters: SerializedFilters }"]:::g
    E["React state\nsetViews(prev =&gt; [...prev, view])"]:::g
    F["Effect: persistViews(calendarId, views)\nlocalStorage['wc-saved-views-{id}']\n{ version: 4, views: SavedView[] }"]:::g
    G["localStorage\nwc-saved-views-{calendarId}"]:::g
    H["loadViews(calendarId)\npage load or calendarId change"]:::g
    I["migrateSavedViewsPayload()\nv1 array → normalizeViews()\nv2–v4 versioned → normalizeViews()\nnone → migrateProfiles(wc-profiles-*)"]:::g
    J["normalizeSavedView()\nfills fields from later versions\n(sort, collapsedGroups, hiddenFromStrip)"]:::g
    K["useSavedViews.views: SavedView[]"]:::g
    L["host applies saved view\ndeserializeFilters(view.filters, schema?)"]:::g
    M["deserializeFilters\nschema multi-select keys → Set&lt;string&gt;\nfallback: categories, resources, sources\ndateRange strings → Date objects"]:::g
    N["live filter state restored\nuseCalendarDataPipeline re-runs\n→ visibleEvents updated"]:::g

